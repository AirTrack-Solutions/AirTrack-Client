# AirTrack Linux Client — Configuration
# Copy this file to .env and fill in your values before starting.
# The install.sh script does this automatically.

# ── Application ──────────────────────────────────────────────────────────────
AIRTRACK_ROLE=client
AIRTRACK_PORT=5000
TZ=UTC

# ── Database ─────────────────────────────────────────────────────────────────
# Change these passwords to something strong and unique.
# Do not use the defaults on a live system.
DB_HOST=airtrack-db
DB_USER=airtrack
DB_PASSWORD=CHANGE_ME
DB_NAME=airtrack
MYSQL_USER=airtrack
MYSQL_PASSWORD=CHANGE_ME
MYSQL_DATABASE=airtrack
MARIADB_ROOT_PASSWORD=CHANGE_ME_ROOT

# ── Wombat (registry delivery) ───────────────────────────────────────────────
# Leave blank for Lite / offline use.
# Set to your Wombat server URL if you have a paid registry subscription.
WOMBAT_URL=
AIRTRACK_CUSTOMER_ID=

# ── Update server ────────────────────────────────────────────────────────────
# Leave blank unless you are running a local AirTrack server.
AIRTRACK_SERVER_URL=
