# AirTrack Client Configuration
# This file is auto-populated by install.sh — you should not need to edit it.
# Do NOT commit .env.client to version control.

# --- Role (do not change) ---
AIRTRACK_ROLE=client
AIRTRACK_UPDATE_MODE=remote
AIRTRACK_FORCE_PUSH=0
AIRTRACK_SYNC_USER=

# --- Source repository (do not change) ---
GIT_REMOTE=https://github.com/Subhuti/AirTrack-Client.git

# --- App paths (do not change) ---
AIRTRACK_APP_DIR=/app
AIRTRACK_STATIC_DIR=/app/static
AIRTRACK_UPDATES_DIR=/app/static/updates
AIRTRACK_LOG_FILE=/app/logs/file_sync.log
AIRTRACK_BACKUP_DIR=/app/logs/backups
AIRTRACK_MAX_ARCHIVES=7
AIRTRACK_SCAN_DIRS=/app/routes;/app/templates;/app/utils;/app/woodland;/app/static/css;/app/static/js
AIRTRACK_EXCLUDE_FILES=/app/utils/file_sync.py

# --- Security (auto-generated by install.sh) ---
SECRET_KEY=your-secret-key-here

# --- Database (auto-generated by install.sh) ---
DB_HOST=airtrack-db
DB_NAME=airtrack
DB_USER=airtrack
DB_PASSWORD=changeme
DB_ROOT_PASSWORD=changeme-root

# --- Linux only (remove on Windows) ---
UID=1000
GID=1000
