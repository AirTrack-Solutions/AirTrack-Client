# === Shared settings (loaded by both Linux + Windows updaters) ===
GITHUB_OWNER=Subhuti
GITHUB_REPO=AirTrack1
GITHUB_BRANCH=main
PKG_PREFIX=subhuti

# Linux install root
LINUX_INSTALL_ROOT=$HOME/docker/AirTrack1

# Windows install root (resolved via %USERPROFILE%)
WINDOWS_INSTALL_REL=\docker\AirTrack-Windows


# Log folder names under each install root
LOG_DIRNAME=logs
RELEASES_DIRNAME=releases
CURRENT_POINTER_NAME=current         # Linux: symlink; Windows: junction + current.txt

